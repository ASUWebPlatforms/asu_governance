#!/bin/bash
# This script is used to add a user to a Drupal site.
# It provides functions to add a user in Drupal using Drush.
# Usage: ./add-user                 [Interactive wizard mode]
#        ./add-user --help           [Show usage instructions]
#        ./add-user --username <username> --site_alias <site_alias> [--stack <stack>]
#
# Examples:
#   ./add-user --username jdoe --site_alias @self              # Local single site (no stack needed)
#   ./add-user --username jdoe --site_alias @mysite.dev        # Remote single site (no stack needed)
#   ./add-user --username jdoe --site_alias allsites --stack 1 # All sites on a specific stack

# ========================== Color Codes ====================================

# Define color codes
RED='\033[0;31m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

# ========================== Configuration ==================================

# Define the drush alias for applying changes to all sites via acsf-tools
ALL_SITES_ALIAS="@websparkci"

DEFAULT_ENVIRONMENT="live"

# Define available Acquia Site Factory stacks
# Keys correspond to ACSF stack numbers
declare -A STACKS=(
  [0]="All stacks"
  [1]="Webspark Stack"
  [3]="Drupal Stack"
  [4]="Webspark Stack [Drupal 9]"
)

# ========================== Functions -----------------------------------

# Handle initial authentication via Acquia secrets and ssh
function authenticate() {
  if [ -z "${ACQUIA_FACTORY_URL:-}" ]; then echo "Please make sure you have set ACQUIA_FACTORY_URL in your project or global config" && exit 1; fi
  if [ -z "${ACQUIA_API_KEY:-}" ] || [ -z "${ACQUIA_API_SECRET:-}" ]; then echo "Please make sure you have set ACQUIA_API_KEY and ACQUIA_API_SECRET in your project or global config" && exit 1; fi
  if [ -z "${ACQUIA_ACSF_USERNAME:-}" ] || [ -z "${ACQUIA_ACSF_KEY:-}" ]; then echo "Please make sure you have set ACQUIA_ACSF_USERNAME and ACQUIA_ACSF_KEY in your project or global config" && exit 1; fi
  if [ -z "${AH_ORGANIZATION_UUID:-}" ]; then echo "Please make sure you have set AH_ORGANIZATION_UUID in your project or global config" && exit 1; fi
  if ! command -v ddev drush >/dev/null; then echo "Please make sure your project contains drush, ddev composer require drush/drush" && exit 1; fi
  ssh-add -l >/dev/null || { echo "Please 'ddev auth ssh' before running this command." && exit 1; }
  acli auth:login -n --key="${ACQUIA_API_KEY}" --secret="${ACQUIA_API_SECRET}"
  acli auth:acsf-login --username="${ACQUIA_ACSF_USERNAME}" --key="${ACQUIA_ACSF_KEY}" --factory-url="${ACQUIA_FACTORY_URL}"
}

# Extract environment from alias (format: alias.env)
# Example: mysite.dev -> dev, mysite.local -> local
function extract_env_from_alias() {
  local alias=$1
  # Extract the environment part (everything after the last dot)
  echo "${alias##*.}"
}

# Validate that environment is not "local"
function validate_env_not_local() {
  local alias=$1
  if [ "$alias" = "@self" ]; then
    # If alias is @self, that means it is local, so return false
    return 1
  fi
  local env=$(extract_env_from_alias "$alias")

  if [ "$env" = "local" ]; then
    return 1
  fi
  return 0
}

# Function to manage add a user
function add_user() {
  local username=$1
  local stack=$2
  local site_alias=$3
  local environment=${4:-$DEFAULT_ENVIRONMENT}

  # Check if site_alias is specified (single site) or empty (all sites)
  if [ -z "$site_alias" ]; then
    # All sites mode - use acsf-tools:mlc with ALL_SITES_ALIAS
    local full_alias="${ALL_SITES_ALIAS}.${environment}"
    # Validate that full_alias is not a local environment
    if ! validate_env_not_local "$full_alias"; then
      echo -e "  ${RED}✗ [error]${NC} Cannot apply changes to all sites on a local environment."
      echo "  Please specify a specific site alias for local development."
      return 1
    fi

    echo "  Adding user $username on stack: $stack (all sites, env: $environment)..."
    if drush ${full_alias} acsf-tools:mlc user:create "'$username' '--mail=${username}@asu.edu'" --no-interaction 2>&1; then
      echo -e "  ${CYAN} [info] The attempt to add the user $username to all sites on $stack has completed.${NC}"
      echo -e "  ${YELLOW} [note] Please review the output above for any errors or warnings. Make note of any sites that may have failed to update, make adjustments and try again, or update them one-by-one (as appropriate).${NC}"
      return 0
    else
      echo -e "  ${RED}✗ [error]${NC} Failed to add $username to all sites on $stack"
      return 1
    fi
  else
    # Single site mode - use regular drush user create commands
    echo "  Adding $username on stack: $stack (site_alias: $site_alias)..."
    if drush ${site_alias} user:create $username --mail=${username}@asu.edu --no-interaction 2>&1; then
      echo -e "  ${GREEN}✓ [success]${NC} Successfully added user: $username on '$stack' $site_alias"
      return 0
    else
      echo -e "  ${RED}✗ [error]${NC} Failed to add user: $username on '$stack' $site_alias"
      return 1
    fi
  fi
}

# ========================== Wizard UI Functions =============================

# Get sorted stack keys (associative arrays are unordered, so sort numerically)
function get_sorted_stack_keys() {
  printf '%s\n' "${!STACKS[@]}" | sort -n
}

# Get list of available stacks (sorted by key)
function get_available_stacks() {
  while IFS= read -r key; do
    echo "${STACKS[$key]}"
  done < <(get_sorted_stack_keys)
}

# Print header
function print_header() {
  echo ""
  echo -e "${GREEN}╔════════════════════════════════════════════════════════════╗"
  echo -e         "║      ASU Governance Add User - Interactive Wizard          ║"
  echo -e         "║                     -------------                          ║"
  echo -e         "║               For use by ET Web Team only.                 ║"
  echo -e         "║      Requirements for use:                                 ║"
  echo -e         "║        - appropriate SSH access permissions on Acqiua      ║"
  echo -e         "║        - Drush aliases for targeted sites                  ║"
  echo -e         "║          (Can be obtained via 'ddev asusf:aliases')        ║"
  echo -e         "╚════════════════════════════════════════════════════════════╝${NC}"
}

# Print menu with options
function print_menu() {
  local title=$1
  shift
  local options=("$@")

  echo -e "$title"
  echo ""
  for i in "${!options[@]}"; do
    echo "  $((i+1))) ${options[$i]}"
  done
  echo ""
}

# Get user input from menu
function get_menu_input() {
  local prompt=$1
  local num_options=$2
  local choice=""

  while [[ ! "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt "$num_options" ]; do
    echo -ne "$prompt" >&2
    read -r choice < /dev/tty

    if [[ ! "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt "$num_options" ]; then
      echo -e "${RED}✗ [error]${NC} Invalid selection. Please enter a number between 1 and $num_options." >&2
      echo "" >&2
    fi
  done

  echo "$choice"
}

# Get text input from user
function get_text_input() {
  local prompt=$1
  local input=""

  while [ -z "$input" ]; do
    echo -ne "$prompt" >&2
    read -r input < /dev/tty

    if [ -z "$input" ]; then
      echo -e "${RED}✗ [error]${NC} Input cannot be empty. Please try again." >&2
    fi
  done

  echo "$input"
}


# ========================== Wizard Flow Functions ============================

# Main wizard flow
function run_wizard() {
  print_header

  # Step 1: Get username
  echo ""
  local username=$(get_text_input "${YELLOW}Step 1: Enter the username (ASURITE Id):${NC} ")

  # Step 2: Ask if targeting single site or multiple sites
  echo ""
  local site_mode_options=("Single site" "Multiple sites")
  print_menu "${YELLOW}Step 2: Are you targeting a single site or multiple sites?${NC}" "${site_mode_options[@]}"
  local site_mode_choice=$(get_menu_input "${YELLOW}Enter your choice:${NC} " "${#site_mode_options[@]}")

  local selected_stacks=()
  local site_alias=""

  if [ "$site_mode_choice" -eq 1 ]; then
    # Single site mode - skip stack selection, go directly to site alias input
    echo ""
    site_alias=$(get_text_input "${YELLOW}Step 3: Enter the site alias (e.g. @websparkci.live, @self):${NC} ")
    # For single site, we don't need to select stacks - it will use drush @{site_alias} directly
    # Set a placeholder to indicate single site mode
    selected_stacks=("single-site-mode")
  else
    # Multiple sites mode - select stack(s) and apply to all sites on those stacks

    # Validate that ALL_SITES_ALIAS is not a local environment
    if ! validate_env_not_local "$ALL_SITES_ALIAS"; then
      echo -e "${RED}✗ [error] Multiple sites mode is not available for local environments.${NC}"
      echo -e "${YELLOW}Please use single site mode and specify a site alias.${NC}"
      echo ""
      return
    fi

    # Step 3: Select stack(s)
    echo ""
    echo -e "${YELLOW}Step 3: Select stack(s) to apply changes to all sites:${NC}"
    echo ""
    while IFS= read -r key; do
      echo " - ${STACKS[$key]} ($key)"
    done < <(get_sorted_stack_keys)
    echo ""

    # Get stack selection - validate against actual stack keys
    local stack_choice=""
    while true; do
      echo -ne "${YELLOW}Enter stack number:${NC} " >&2
      read -r stack_choice < /dev/tty

      if [[ "$stack_choice" =~ ^[0-9]+$ ]]; then
        if [ "$stack_choice" -eq 0 ] || [ -n "${STACKS[$stack_choice]+x}" ]; then
          break
        fi
      fi
      local valid_keys
      valid_keys=$(get_sorted_stack_keys | tr '\n' ', ' | sed 's/,$//')
      echo -e "${RED}✗ [error]${NC} Invalid selection. Enter a valid stack number ($valid_keys) or 0 for all stacks." >&2
      echo "" >&2
    done

    if [ "$stack_choice" -eq 0 ]; then
      # All stacks selected
      while IFS= read -r key; do
        selected_stacks+=("${STACKS[$key]}")
      done < <(get_sorted_stack_keys)
    else
      # Single stack selected
      selected_stacks=("${STACKS[$stack_choice]}")
    fi

    # site_alias remains empty, which triggers all-sites mode in add_user()

    # Step 4: Select environment
    echo ""
    local environments=("live" "test" "dev")
    print_menu "${YELLOW}Step 4: Which environment would you like to target? [default: ${DEFAULT_ENVIRONMENT}]${NC}" "${environments[@]}"
    local env_choice=$(get_menu_input "${YELLOW}Enter your choice:${NC} " "${#environments[@]}")
    local selected_env="${environments[$((env_choice - 1))]}"
  fi

  # Step 5 (for both flows): Confirm action
  echo ""
  echo -e "${YELLOW}Step 5: Please review your selection:${NC}"
  echo ""
  echo -ne "${CYAN}Are you sure you want to ${YELLOW}add${CYAN} the user ${YELLOW}${username}${NC}"

  if [ "$site_mode_choice" -eq 1 ]; then
    # Single site mode
    echo -e " ${CYAN}on site: ${YELLOW}$site_alias${NC}"
  else
    echo -e " ${CYAN}on the following:${NC}"
    echo -e "${YELLOW}  - ${STACKS[$stack_choice]} (all sites, environment: $selected_env)\n${NC}"
  fi

  echo -ne "${CYAN}Do you want to continue? (yes/no) [${YELLOW}yes${CYAN}]:${NC} "
  read -r response < /dev/tty

  # Default to 'yes' if user just presses Enter
  if [ -z "$response" ]; then
    response="yes"
  fi

  # Accept 'y', 'Y', or any variation of 'yes' (case-insensitive)
  if ! [[ "$response" =~ ^[Yy]([Ee][Ss])?$ ]]; then
    echo -e "${RED}✗ [error]${NC} Action cancelled."
    echo ""
    return
  fi

  # Step 6: Execute action
  echo ""
  echo -e "${YELLOW}Step 6: Executing...${NC}"
  echo ""

  if [ "$site_mode_choice" -eq 1 ]; then
    # Single site mode - execute directly with site alias, no stack needed
    add_user "$username" "single-site" "$site_alias"
  else
    # Multiple sites mode - iterate through stacks, site_alias is empty (all sites)
    for stack in "${selected_stacks[@]}"; do
      add_user "$username" "$stack" "" "$selected_env"
    done
  fi

  echo ""
}

# ========================== Flag Parsing & Help =============================

# Print usage information
function print_usage() {
  cat << EOF

╔════════════════════════════════════════════════════════════╗
║        ASU Governance Add User - Usage Information         ║
╚════════════════════════════════════════════════════════════╝

OPTIONS:
  --username=<username>        Required. The username (ASURITE Id) to manage
  --stack=<stack_number>       Optional for single-site targets, required for 'allsites'.
                               Stack number (0 = all stacks, or a specific stack number).
                               Not needed when --site-alias is a specific site (e.g., @self).
  --site-alias=<alias>         Required. Site alias (e.g., @alias.env, @self).
                               Use special value 'allsites' to apply to all sites on the selected stack(s).
                               Note: For local environments, you must specify a site alias and cannot use 'allsites' or target multiple stacks.
  --help                       Display this help message

AVAILABLE STACKS:
EOF
  while IFS= read -r key; do
    echo "  $key. ${STACKS[$key]}"
  done < <(get_sorted_stack_keys)
  cat << EOF
EOF
}

# Parse command-line flags and execute
function handle_flags() {
  local username=""
  local stack_index=""
  local site_alias=""  # No default - must be explicitly specified

  while [[ $# -gt 0 ]]; do
    case $1 in
      --help|-h)
        print_usage
        exit 0
        ;;
      --username)
        username="$2"
        shift 2
        ;;
      --stack)
        stack_index="$2"
        shift 2
        ;;
      --site_alias)
        site_alias="$2"
        shift 2
        ;;
      *)
        echo -e "${RED}✗ [error]${NC} Unknown option: $1"
        print_usage
        exit 1
        ;;
    esac
  done

  # Validate that username is provided
  if [ -z "$username" ]; then
    echo -e "${RED}✗ [error]${NC} --username is required when using flags."
    print_usage
    exit 1
  fi

  # Require explicit site_alias specification to match wizard mode's explicit choice
  if [ -z "$site_alias" ]; then
    echo -e "${RED}✗ [error]${NC} --site_alias is required when using flags."
    echo "  Use --site_alias allsites to apply to all sites on the selected stack(s),"
    echo "  or specify a site alias (e.g., --site_alias @mysite.dev, @self) for a specific site."
    print_usage
    exit 1
  fi

  # Determine site to use based on site_alias value
  if [ "$site_alias" = "allsites" ]; then
    # All-sites mode: --stack is required
    if [ -z "$stack_index" ]; then
      echo -e "${RED}✗ [error]${NC} --stack is required when using --site_alias allsites."
      print_usage
      exit 1
    fi

    # Validate stack_index is a number
    if ! [[ "$stack_index" =~ ^[0-9]+$ ]]; then
      echo -e "${RED}✗ [error]${NC} Invalid stack index '$stack_index'. Must be a number (0 for all stacks, 1-N for specific stack)."
      print_usage
      exit 1
    fi

    # Determine stacks to use based on stack_index
    local target_stacks=()

    if [ "$stack_index" -eq 0 ]; then
      # 0 means all stacks
      while IFS= read -r key; do
        target_stacks+=("${STACKS[$key]}")
      done < <(get_sorted_stack_keys)
    elif [ -n "${STACKS[$stack_index]+x}" ]; then
      # Valid stack key - look up directly in associative array
      target_stacks=("${STACKS[$stack_index]}")
    else
      local valid_keys
      valid_keys=$(get_sorted_stack_keys | tr '\n' ', ' | sed 's/,$//')
      echo -e "${RED}✗ [error]${NC} Invalid stack number '$stack_index'. Valid stack numbers are: $valid_keys (or 0 for all stacks)."
      print_usage
      exit 1
    fi

    # Execute all-sites mode (site_alias empty triggers multi-site in add_user)
    echo ""
    for s in "${target_stacks[@]}"; do
      echo "Processing user: $username on stack: $s (all sites)..."
      add_user "$username" "$s" ""
    done
    echo ""
  else
    # Single-site mode: --stack is optional (defaults to "local" label)
    local stack_label="local"
    if [ -n "$stack_index" ]; then
      # Stack was provided — validate and use it for the label
      if ! [[ "$stack_index" =~ ^[0-9]+$ ]]; then
        echo -e "${RED}✗ [error]${NC} Invalid stack index '$stack_index'. Must be a number (0 for all stacks, 1-N for specific stack)."
        print_usage
        exit 1
      fi
      if [ -n "${STACKS[$stack_index]+x}" ]; then
        stack_label="${STACKS[$stack_index]}"
      else
        local valid_keys
        valid_keys=$(get_sorted_stack_keys | tr '\n' ', ' | sed 's/,$//')
        echo -e "${RED}✗ [error]${NC} Invalid stack number '$stack_index'. Valid stack numbers are: $valid_keys (or 0 for all stacks)."
        print_usage
        exit 1
      fi
    fi

    # Execute single-site mode
    echo ""
    echo "Processing user: $username on site: $site_alias..."
    add_user "$username" "$stack_label" "$site_alias"
    echo ""
  fi
}

# ========================== Main Script =============================

# -------- Ensure SSH keys are synchronized (when DDEV is available) --------
if command -v ddev >/dev/null 2>&1; then
  # Capture the output of the command
  output=$(ddev drush @asufactory1.01live list 2>&1)

  # Check if the output contains the error message
  if echo "$output" | grep -q "Permission denied (publickey)"; then
    echo "❌ SSH key synchronization failed. Please run 'ddev auth ssh' and try again."
    exit 1
  fi
fi

authenticate || (printf "Failed to authenticate" && exit $?)

# Check if any arguments were provided
if [ $# -eq 0 ]; then
  # No arguments - run interactive wizard
  run_wizard
else
  # Arguments provided - parse them as flags
  handle_flags "$@"
fi
